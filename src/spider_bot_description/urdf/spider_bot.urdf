<?xml version="1.0"?>
<robot name="spider_bot">

  <!-- ============================================================
       SPIDER BOT — 12 DOF Quadruped
       Body  : 15 x 11 x 4.5 cm
       Coxa  : 3.5 cm  |  Femur : 7.0 cm  |  Tibia : 7.5 cm
       ============================================================ -->

  <material name="body_color"><color rgba="0.15 0.15 0.15 1.0"/></material>
  <material name="leg_color"> <color rgba="0.85 0.40 0.05 1.0"/></material>
  <material name="foot_color"><color rgba="0.9  0.9  0.9  1.0"/></material>

  <link name="base_link">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="0.15 0.11 0.045"/></geometry><material name="body_color"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="0.15 0.11 0.045"/></geometry></collision>
    <inertial><origin xyz="0 0 0"/><mass value="0.5"/><inertia ixx="5.88e-4" ixy="0" ixz="0" iyy="1.02e-3" iyz="0" izz="1.44e-3"/></inertial>
  </link>

  <!-- FL -->
  <joint name="fl_coxa_joint" type="revolute">
    <parent link="base_link"/><child link="fl_coxa_link"/>
    <origin xyz="0.075 0.055 0.0" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.523" upper="0.523" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="fl_coxa_link">
    <visual><origin xyz="0 0.0175 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.008" length="0.035"/></geometry><material name="leg_color"/></visual>
    <collision><origin xyz="0 0.0175 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.008" length="0.035"/></geometry></collision>
    <inertial><origin xyz="0 0.0175 0"/><mass value="0.05"/><inertia ixx="5.9e-6" ixy="0" ixz="0" iyy="1.6e-6" iyz="0" izz="5.9e-6"/></inertial>
  </link>

  <joint name="fl_femur_joint" type="revolute">
    <parent link="fl_coxa_link"/><child link="fl_femur_link"/>
    <origin xyz="0 0.035 0.0" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.571" upper="1.571" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="fl_femur_link">
    <visual><origin xyz="0 0 -0.035" rpy="0 0 0"/><geometry><cylinder radius="0.008" length="0.07"/></geometry><material name="body_color"/></visual>
    <collision><origin xyz="0 0 -0.035" rpy="0 0 0"/><geometry><cylinder radius="0.008" length="0.07"/></geometry></collision>
    <inertial><origin xyz="0 0 -0.035"/><mass value="0.05"/><inertia ixx="2.12e-5" ixy="0" ixz="0" iyy="2.12e-5" iyz="0" izz="1.6e-6"/></inertial>
  </link>

  <joint name="fl_tibia_joint" type="revolute">
    <parent link="fl_femur_link"/><child link="fl_tibia_link"/>
    <origin xyz="0 0 -0.07" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.571" upper="1.571" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="fl_tibia_link">
    <visual><origin xyz="0 0 -0.0375" rpy="0 0 0"/><geometry><cylinder radius="0.007" length="0.075"/></geometry><material name="leg_color"/></visual>
    <collision><origin xyz="0 0 -0.0375" rpy="0 0 0"/><geometry><cylinder radius="0.007" length="0.075"/></geometry></collision>
    <inertial><origin xyz="0 0 -0.0375"/><mass value="0.03"/><inertia ixx="1.44e-5" ixy="0" ixz="0" iyy="1.44e-5" iyz="0" izz="7.35e-7"/></inertial>
  </link>

  <joint name="fl_foot_joint" type="fixed">
    <parent link="fl_tibia_link"/><child link="fl_foot_link"/>
    <origin xyz="0 0 -0.075" rpy="0 0 0"/>
  </joint>
  <link name="fl_foot_link">
    <visual><origin xyz="0 0 0"/><geometry><sphere radius="0.01"/></geometry><material name="foot_color"/></visual>
    <collision><origin xyz="0 0 0"/><geometry><sphere radius="0.01"/></geometry></collision>
    <inertial><mass value="0.005"/><inertia ixx="2.0e-9" ixy="0" ixz="0" iyy="2.0e-9" iyz="0" izz="2.0e-9"/></inertial>
  </link>

  <!-- FR -->
  <joint name="fr_coxa_joint" type="revolute">
    <parent link="base_link"/><child link="fr_coxa_link"/>
    <origin xyz="0.075 -0.055 0.0" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.523" upper="0.523" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="fr_coxa_link">
    <visual><origin xyz="0 -0.0175 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.008" length="0.035"/></geometry><material name="leg_color"/></visual>
    <collision><origin xyz="0 -0.0175 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.008" length="0.035"/></geometry></collision>
    <inertial><origin xyz="0 -0.0175 0"/><mass value="0.05"/><inertia ixx="5.9e-6" ixy="0" ixz="0" iyy="1.6e-6" iyz="0" izz="5.9e-6"/></inertial>
  </link>

  <joint name="fr_femur_joint" type="revolute">
    <parent link="fr_coxa_link"/><child link="fr_femur_link"/>
    <origin xyz="0 -0.035 0.0" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.571" upper="1.571" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="fr_femur_link">
    <visual><origin xyz="0 0 -0.035" rpy="0 0 0"/><geometry><cylinder radius="0.008" length="0.07"/></geometry><material name="body_color"/></visual>
    <collision><origin xyz="0 0 -0.035" rpy="0 0 0"/><geometry><cylinder radius="0.008" length="0.07"/></geometry></collision>
    <inertial><origin xyz="0 0 -0.035"/><mass value="0.05"/><inertia ixx="2.12e-5" ixy="0" ixz="0" iyy="2.12e-5" iyz="0" izz="1.6e-6"/></inertial>
  </link>

  <joint name="fr_tibia_joint" type="revolute">
    <parent link="fr_femur_link"/><child link="fr_tibia_link"/>
    <origin xyz="0 0 -0.07" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.571" upper="1.571" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="fr_tibia_link">
    <visual><origin xyz="0 0 -0.0375" rpy="0 0 0"/><geometry><cylinder radius="0.007" length="0.075"/></geometry><material name="leg_color"/></visual>
    <collision><origin xyz="0 0 -0.0375" rpy="0 0 0"/><geometry><cylinder radius="0.007" length="0.075"/></geometry></collision>
    <inertial><origin xyz="0 0 -0.0375"/><mass value="0.03"/><inertia ixx="1.44e-5" ixy="0" ixz="0" iyy="1.44e-5" iyz="0" izz="7.35e-7"/></inertial>
  </link>

  <joint name="fr_foot_joint" type="fixed">
    <parent link="fr_tibia_link"/><child link="fr_foot_link"/>
    <origin xyz="0 0 -0.075" rpy="0 0 0"/>
  </joint>
  <link name="fr_foot_link">
    <visual><origin xyz="0 0 0"/><geometry><sphere radius="0.01"/></geometry><material name="foot_color"/></visual>
    <collision><origin xyz="0 0 0"/><geometry><sphere radius="0.01"/></geometry></collision>
    <inertial><mass value="0.005"/><inertia ixx="2.0e-9" ixy="0" ixz="0" iyy="2.0e-9" iyz="0" izz="2.0e-9"/></inertial>
  </link>

  <!-- RL -->
  <joint name="rl_coxa_joint" type="revolute">
    <parent link="base_link"/><child link="rl_coxa_link"/>
    <origin xyz="-0.075 0.055 0.0" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.523" upper="0.523" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="rl_coxa_link">
    <visual><origin xyz="0 0.0175 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.008" length="0.035"/></geometry><material name="leg_color"/></visual>
    <collision><origin xyz="0 0.0175 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.008" length="0.035"/></geometry></collision>
    <inertial><origin xyz="0 0.0175 0"/><mass value="0.05"/><inertia ixx="5.9e-6" ixy="0" ixz="0" iyy="1.6e-6" iyz="0" izz="5.9e-6"/></inertial>
  </link>

  <joint name="rl_femur_joint" type="revolute">
    <parent link="rl_coxa_link"/><child link="rl_femur_link"/>
    <origin xyz="0 0.035 0.0" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.571" upper="1.571" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="rl_femur_link">
    <visual><origin xyz="0 0 -0.035" rpy="0 0 0"/><geometry><cylinder radius="0.008" length="0.07"/></geometry><material name="body_color"/></visual>
    <collision><origin xyz="0 0 -0.035" rpy="0 0 0"/><geometry><cylinder radius="0.008" length="0.07"/></geometry></collision>
    <inertial><origin xyz="0 0 -0.035"/><mass value="0.05"/><inertia ixx="2.12e-5" ixy="0" ixz="0" iyy="2.12e-5" iyz="0" izz="1.6e-6"/></inertial>
  </link>

  <joint name="rl_tibia_joint" type="revolute">
    <parent link="rl_femur_link"/><child link="rl_tibia_link"/>
    <origin xyz="0 0 -0.07" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.571" upper="1.571" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="rl_tibia_link">
    <visual><origin xyz="0 0 -0.0375" rpy="0 0 0"/><geometry><cylinder radius="0.007" length="0.075"/></geometry><material name="leg_color"/></visual>
    <collision><origin xyz="0 0 -0.0375" rpy="0 0 0"/><geometry><cylinder radius="0.007" length="0.075"/></geometry></collision>
    <inertial><origin xyz="0 0 -0.0375"/><mass value="0.03"/><inertia ixx="1.44e-5" ixy="0" ixz="0" iyy="1.44e-5" iyz="0" izz="7.35e-7"/></inertial>
  </link>

  <joint name="rl_foot_joint" type="fixed">
    <parent link="rl_tibia_link"/><child link="rl_foot_link"/>
    <origin xyz="0 0 -0.075" rpy="0 0 0"/>
  </joint>
  <link name="rl_foot_link">
    <visual><origin xyz="0 0 0"/><geometry><sphere radius="0.01"/></geometry><material name="foot_color"/></visual>
    <collision><origin xyz="0 0 0"/><geometry><sphere radius="0.01"/></geometry></collision>
    <inertial><mass value="0.005"/><inertia ixx="2.0e-9" ixy="0" ixz="0" iyy="2.0e-9" iyz="0" izz="2.0e-9"/></inertial>
  </link>

  <!-- RR -->
  <joint name="rr_coxa_joint" type="revolute">
    <parent link="base_link"/><child link="rr_coxa_link"/>
    <origin xyz="-0.075 -0.055 0.0" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.523" upper="0.523" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="rr_coxa_link">
    <visual><origin xyz="0 -0.0175 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.008" length="0.035"/></geometry><material name="leg_color"/></visual>
    <collision><origin xyz="0 -0.0175 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.008" length="0.035"/></geometry></collision>
    <inertial><origin xyz="0 -0.0175 0"/><mass value="0.05"/><inertia ixx="5.9e-6" ixy="0" ixz="0" iyy="1.6e-6" iyz="0" izz="5.9e-6"/></inertial>
  </link>

  <joint name="rr_femur_joint" type="revolute">
    <parent link="rr_coxa_link"/><child link="rr_femur_link"/>
    <origin xyz="0 -0.035 0.0" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.571" upper="1.571" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="rr_femur_link">
    <visual><origin xyz="0 0 -0.035" rpy="0 0 0"/><geometry><cylinder radius="0.008" length="0.07"/></geometry><material name="body_color"/></visual>
    <collision><origin xyz="0 0 -0.035" rpy="0 0 0"/><geometry><cylinder radius="0.008" length="0.07"/></geometry></collision>
    <inertial><origin xyz="0 0 -0.035"/><mass value="0.05"/><inertia ixx="2.12e-5" ixy="0" ixz="0" iyy="2.12e-5" iyz="0" izz="1.6e-6"/></inertial>
  </link>

  <joint name="rr_tibia_joint" type="revolute">
    <parent link="rr_femur_link"/><child link="rr_tibia_link"/>
    <origin xyz="0 0 -0.07" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-1.571" upper="1.571" effort="10.0" velocity="1.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>
  <link name="rr_tibia_link">
    <visual><origin xyz="0 0 -0.0375" rpy="0 0 0"/><geometry><cylinder radius="0.007" length="0.075"/></geometry><material name="leg_color"/></visual>
    <collision><origin xyz="0 0 -0.0375" rpy="0 0 0"/><geometry><cylinder radius="0.007" length="0.075"/></geometry></collision>
    <inertial><origin xyz="0 0 -0.0375"/><mass value="0.03"/><inertia ixx="1.44e-5" ixy="0" ixz="0" iyy="1.44e-5" iyz="0" izz="7.35e-7"/></inertial>
  </link>

  <joint name="rr_foot_joint" type="fixed">
    <parent link="rr_tibia_link"/><child link="rr_foot_link"/>
    <origin xyz="0 0 -0.075" rpy="0 0 0"/>
  </joint>
  <link name="rr_foot_link">
    <visual><origin xyz="0 0 0"/><geometry><sphere radius="0.01"/></geometry><material name="foot_color"/></visual>
    <collision><origin xyz="0 0 0"/><geometry><sphere radius="0.01"/></geometry></collision>
    <inertial><mass value="0.005"/><inertia ixx="2.0e-9" ixy="0" ixz="0" iyy="2.0e-9" iyz="0" izz="2.0e-9"/></inertial>
  </link>

  <!-- ros2_control -->
  <ros2_control name="spider_bot_gz" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="fl_coxa_joint">  <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="fl_femur_joint"> <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="fl_tibia_joint"> <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="fr_coxa_joint">  <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="fr_femur_joint"> <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="fr_tibia_joint"> <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="rl_coxa_joint">  <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="rl_femur_joint"> <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="rl_tibia_joint"> <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="rr_coxa_joint">  <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="rr_femur_joint"> <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
    <joint name="rr_tibia_joint"> <command_interface name="position"/> <state_interface name="position"/> <state_interface name="velocity"/> </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find spider_bot_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="base_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="fl_coxa_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="fl_femur_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="fl_tibia_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="fl_foot_link"><material>Gazebo/White</material><mu1>1.0</mu1><mu2>1.0</mu2><kp>1000000.0</kp><kd>1.0</kd></gazebo>
  <gazebo reference="fr_coxa_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="fr_femur_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="fr_tibia_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="fr_foot_link"><material>Gazebo/White</material><mu1>1.0</mu1><mu2>1.0</mu2><kp>1000000.0</kp><kd>1.0</kd></gazebo>
  <gazebo reference="rl_coxa_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="rl_femur_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="rl_tibia_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="rl_foot_link"><material>Gazebo/White</material><mu1>1.0</mu1><mu2>1.0</mu2><kp>1000000.0</kp><kd>1.0</kd></gazebo>
  <gazebo reference="rr_coxa_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="rr_femur_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="rr_tibia_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="rr_foot_link"><material>Gazebo/White</material><mu1>1.0</mu1><mu2>1.0</mu2><kp>1000000.0</kp><kd>1.0</kd></gazebo>

</robot>
